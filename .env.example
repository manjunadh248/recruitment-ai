# ═══════════════════════════════════
# RecruitAI Environment Configuration
# ═══════════════════════════════════

# App
APP_NAME=RecruitAI
APP_ENV=development
DEBUG=true
API_VERSION=v1
SECRET_KEY=your-super-secret-key-change-in-production

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# MongoDB
MONGODB_URL=mongodb://recruitai_user:recruitai_pass@mongodb:27017/recruitai?authSource=admin
MONGODB_DB_NAME=recruitai
MONGO_INITDB_ROOT_USERNAME=recruitai_user
MONGO_INITDB_ROOT_PASSWORD=recruitai_pass

# Redis
REDIS_URL=redis://redis:6379/0

# AI/LLM
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
LLM_PROVIDER=openai

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=RecruitAI

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
